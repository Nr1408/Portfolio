{
  "version": 2,
  "buildCommand": "node node_modules/vite/bin/vite.js build",
  "builds": [
    { "src": "dist/server/server.js", "use": "@vercel/edge" },
    { "src": "dist/client/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "dist/server/server.js" }
  ]
}
